# daimon-memory configuration. Copy to .env (or run ./install.sh, which writes it).
# .env is gitignored - never commit real secrets.

# ── Docker Compose path (docker-compose.yml reads these) ──────────────────────
DAIMON_PORT=8080
DAIMON_PG_PASSWORD=change-me
DAIMON_DEFAULT_TENANT=00000000-0000-0000-0000-0000000000d1

# ── Running the binaries against your own Postgres + Qdrant (source these) ─────
# PGHOST=localhost
# PGPORT=5432
# PGUSER=daimon
# PGPASSWORD=change-me
# PGDATABASE=daimon_memory
# DAIMON_QDRANT_URL=http://localhost:6334     # gRPC port (NOT the 6333 REST port)
# DAIMON_MCP_BIND=0.0.0.0:8080
# DAIMON_DEFAULT_TENANT=00000000-0000-0000-0000-0000000000d1
# RUST_LOG=info

# ── daimon CLI: persona / protocol commands POST to the running server ─────────
# DAIMON_ENDPOINT=http://localhost:8080                # where daimon-mcp is reachable
# DAIMON_TENANT=00000000-0000-0000-0000-0000000000d1   # which memory space to write to

# Client/plugin knobs (DAIMON_NUDGE_CADENCE, DAIMON_RECALL_MIN_COSINE, DAIMON_NUDGE,
# DAIMON_API_KEY, DAIMON_NAMESPACE) are set per-tool by the integration installers,
# not here. See integrations/.
